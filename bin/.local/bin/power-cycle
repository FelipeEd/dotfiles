#!/bin/bash

profiles=(low-power quiet balanced performance)

current=$(cat /sys/firmware/acpi/platform_profile)

for i in "${!profiles[@]}"; do
    if [[ "${profiles[$i]}" == "$current" ]]; then
        next=${profiles[$(( (i + 1) % ${#profiles[@]} ))]}
        break
    fi
done

pkexec /usr/local/bin/platform-profile-set "$next"
